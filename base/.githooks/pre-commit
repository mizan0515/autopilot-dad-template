#!/usr/bin/env sh
set -eu

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$repo_root"

if command -v pwsh >/dev/null 2>&1; then
  runner="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  runner="powershell"
elif command -v powershell.exe >/dev/null 2>&1; then
  runner="powershell.exe"
else
  echo "PowerShell not found. Install pwsh 7.2+ or ensure powershell(.exe) is on PATH before using .githooks/pre-commit." >&2
  exit 1
fi

"$runner" -ExecutionPolicy Bypass -File tools/Validate-Documents.ps1 -Root . -IncludeRootGuides -IncludeAgentDocs -ReportLargeRootGuides -FailOnLargeDocs
"$runner" -ExecutionPolicy Bypass -File tools/Validate-CodexSkillMetadata.ps1 -RepoRoot .
"$runner" -ExecutionPolicy Bypass -File tools/Register-CodexSkills.ps1 -RepoRoot . -SkillHome "$repo_root/.git/.codex-hook-validate" -ValidateOnly
"$runner" -ExecutionPolicy Bypass -File tools/Lint-StaleTerms.ps1
"$runner" -ExecutionPolicy Bypass -File tools/Validate-DadDecisions.ps1 -Root .
"$runner" -ExecutionPolicy Bypass -File tools/Validate-DadDecisionWorkflow.ps1 -Root .
"$runner" -ExecutionPolicy Bypass -File tools/Validate-DadPacket.ps1 -Root . -AllSessions
"$runner" -ExecutionPolicy Bypass -File tools/Validate-ImmutableBlocks.ps1 -Root .
# Round-4 F38: ledger consistency soft check. Surfaces drift between
# RUNNER-LIVE.json's last phase and METRICS/FAILURES tail rows that
# share the same run_id (F37). -Soft → drift logged but doesn't block
# the commit, since the most common drift cause is a previous runner
# crash that the agent's current commit may itself be repairing.
"$runner" -ExecutionPolicy Bypass -File tools/Validate-LedgerConsistency.ps1 -AutopilotRoot .autopilot -Soft
# Round-4 F39: runtime-evidence admission soft check. Surfaces shipped
# rows whose active task carries a runtime-required tag but whose
# METRICS row has no `runtime_evidence` field. -Soft → logged, doesn't
# block (initial deployment).
"$runner" -ExecutionPolicy Bypass -File tools/Validate-RuntimeEvidence.ps1 -AutopilotRoot .autopilot -Soft
